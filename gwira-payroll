<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G Wira Trading — Payroll System</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  :root {
    --black: #1a1a1a;
    --yellow: #e8b800;
    --blue: #1a4b8c;
    --green: #1a6b3a;
    --red: #c0392b;
    --orange: #e67e22;
    --grey: #7f8c8d;
    --lgrey: #f5f5f5;
    --lblue: #eaf0fb;
    --lgreen: #eafaf1;
    --lred: #fdf0f0;
    --lyellow: #fefce8;
    --white: #ffffff;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #f0f2f5;
    color: var(--black);
    min-height: 100vh;
  }

  /* NAV */
  .nav {
    background: var(--black);
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 3px solid var(--yellow);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
  }
  .nav-badge {
    background: var(--yellow);
    color: var(--black);
    font-weight: 800;
    font-size: 13px;
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 1px;
  }
  .nav-title {
    color: white;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .nav-tabs {
    display: flex;
    height: 100%;
  }
  .nav-tab {
    padding: 14px 18px;
    color: #aaa;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    border-bottom: 3px solid transparent;
    transition: all 0.2s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    letter-spacing: 0.5px;
  }
  .nav-tab:hover { color: white; }
  .nav-tab.active { color: var(--yellow); border-bottom-color: var(--yellow); }

  /* MAIN */
  .main { max-width: 1000px; margin: 0 auto; padding: 24px 16px; }

  /* CARDS */
  .card {
    background: white;
    border-radius: 8px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    margin-bottom: 20px;
    overflow: hidden;
  }
  .card-header {
    padding: 14px 20px;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
  }
  .card-header.blue { background: var(--blue); }
  .card-header.green { background: var(--green); }
  .card-header.red { background: var(--red); }
  .card-header.black { background: var(--black); }
  .card-header.orange { background: var(--orange); }
  .card-body { padding: 20px; }

  /* FORMS */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
  .form-group { display: flex; flex-direction: column; gap: 5px; }
  .form-group label { font-size: 11px; font-weight: 700; color: var(--grey); text-transform: uppercase; letter-spacing: 0.5px; }
  .form-group input, .form-group select {
    padding: 9px 12px;
    border: 1.5px solid #e0e0e0;
    border-radius: 6px;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
  }
  .form-group input:focus, .form-group select:focus { border-color: var(--blue); }
  .form-full { grid-column: 1 / -1; }

  /* BUTTONS */
  .btn {
    padding: 9px 18px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: opacity 0.2s;
    letter-spacing: 0.5px;
  }
  .btn:hover { opacity: 0.85; }
  .btn-blue { background: var(--blue); color: white; }
  .btn-green { background: var(--green); color: white; }
  .btn-red { background: var(--red); color: white; }
  .btn-yellow { background: var(--yellow); color: var(--black); }
  .btn-grey { background: var(--lgrey); color: var(--black); border: 1px solid #ddd; }
  .btn-sm { padding: 5px 12px; font-size: 11px; }

  /* TABLES */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { background: var(--lgrey); padding: 10px 12px; text-align: left; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--grey); border-bottom: 2px solid #e0e0e0; }
  td { padding: 10px 12px; border-bottom: 1px solid #f0f0f0; }
  tr:hover td { background: var(--lgrey); }
  .td-right { text-align: right; }

  /* BADGES */
  .badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .badge-green { background: var(--lgreen); color: var(--green); }
  .badge-red { background: var(--lred); color: var(--red); }
  .badge-blue { background: var(--lblue); color: var(--blue); }
  .badge-yellow { background: var(--lyellow); color: #856404; }

  /* STATS */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
  .stat-card {
    background: white;
    border-radius: 8px;
    padding: 16px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    border-left: 4px solid var(--blue);
  }
  .stat-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--grey); margin-bottom: 6px; }
  .stat-value { font-size: 22px; font-weight: 800; color: var(--black); }
  .stat-sub { font-size: 11px; color: var(--grey); margin-top: 2px; }

  /* TABS content */
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ALERTS */
  .alert {
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 13px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .alert-green { background: var(--lgreen); border-left: 4px solid var(--green); color: var(--green); }
  .alert-red { background: var(--lred); border-left: 4px solid var(--red); color: var(--red); }
  .alert-blue { background: var(--lblue); border-left: 4px solid var(--blue); color: var(--blue); }

  /* SECTION DIVIDER */
  .section-divider {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--grey);
    margin: 16px 0 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #e0e0e0;
  }

  /* PAYSLIP PRINT STYLES */
  @media print {
    body { background: white; }
    .nav, .main > *:not(#print-area) { display: none !important; }
    #print-area { display: block !important; }
    .payslip { page-break-after: always; }
  }

  #print-area { display: none; }

  .payslip {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    font-family: Arial, sans-serif;
    font-size: 12px;
    border: 1px solid #ccc;
  }
  .ps-header {
    background: #1a1a1a;
    color: white;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ps-company { font-size: 16px; font-weight: 800; }
  .ps-sub { font-size: 10px; color: #aaa; margin-top: 2px; }
  .ps-title { background: #e8b800; color: #1a1a1a; padding: 8px 20px; font-weight: 700; font-size: 13px; letter-spacing: 1px; }
  .ps-body { padding: 16px 20px; }
  .ps-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
  .ps-info-item { display: flex; gap: 8px; }
  .ps-info-label { font-weight: 700; color: #555; min-width: 80px; font-size: 11px; }
  .ps-info-value { font-size: 11px; }
  .ps-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
  .ps-table th { background: #f5f5f5; padding: 7px 10px; text-align: left; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #555; border: 1px solid #e0e0e0; }
  .ps-table td { padding: 7px 10px; border: 1px solid #e0e0e0; font-size: 11px; }
  .ps-table td:last-child { text-align: right; font-weight: 600; }
  .ps-table tr.total-row td { background: #1a1a1a; color: white; font-weight: 700; }
  .ps-table tr.green-row td { background: #eafaf1; }
  .ps-table tr.red-row td { background: #fdf0f0; }
  .ps-net { background: #e8b800; padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; }
  .ps-net-label { font-weight: 800; font-size: 14px; }
  .ps-net-amount { font-weight: 800; font-size: 20px; }
  .ps-footer { padding: 16px 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .ps-sig-line { border-top: 1px solid #ccc; padding-top: 6px; font-size: 10px; color: #555; margin-top: 30px; }

  .modal-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: white;
    border-radius: 8px;
    width: 90%;
    max-width: 500px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    overflow: hidden;
  }
  .modal-header {
    padding: 16px 20px;
    font-weight: 700;
    font-size: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--blue);
    color: white;
  }
  .modal-body { padding: 20px; }
  .modal-footer { padding: 14px 20px; background: var(--lgrey); display: flex; justify-content: flex-end; gap: 10px; }

  .flex { display: flex; gap: 10px; align-items: center; }
  .flex-end { justify-content: flex-end; }
  .mt-10 { margin-top: 10px; }
  .mt-16 { margin-top: 16px; }
  .text-right { text-align: right; }
  .text-green { color: var(--green); font-weight: 700; }
  .text-red { color: var(--red); font-weight: 700; }
  .text-grey { color: var(--grey); }
  .font-bold { font-weight: 700; }
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-brand">
    <div class="nav-badge">G WIRA</div>
    <div class="nav-title">PAYROLL SYSTEM</div>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="switchTab('dashboard')">Dashboard</button>
    <button class="nav-tab" onclick="switchTab('employees')">Employees</button>
    <button class="nav-tab" onclick="switchTab('advances')">Advances</button>
    <button class="nav-tab" onclick="switchTab('deductions')">Deductions</button>
    <button class="nav-tab" onclick="switchTab('payroll')">Payroll</button>
  </div>
</nav>

<!-- PRINT AREA -->
<div id="print-area"></div>

<!-- MAIN -->
<div class="main">

  <!-- DASHBOARD -->
  <div id="tab-dashboard" class="tab-content active">
    <div id="stats-container"></div>
    <div class="card">
      <div class="card-header black">Current Month Summary — <span id="current-month-label"></span></div>
      <div class="card-body">
        <div id="dashboard-table"></div>
      </div>
    </div>
    <div class="card">
      <div class="card-header orange">Pending Advances This Month</div>
      <div class="card-body">
        <div id="advance-summary"></div>
      </div>
    </div>
  </div>

  <!-- EMPLOYEES -->
  <div id="tab-employees" class="tab-content">
    <div class="card">
      <div class="card-header blue">
        Add New Employee
      </div>
      <div class="card-body">
        <div class="form-grid">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" id="emp-name" placeholder="e.g. Kasturi">
          </div>
          <div class="form-group">
            <label>Role</label>
            <input type="text" id="emp-role" placeholder="e.g. Cashier & Admin">
          </div>
          <div class="form-group">
            <label>Basic Salary (RM)</label>
            <input type="number" id="emp-salary" placeholder="e.g. 1900">
          </div>
          <div class="form-group">
            <label>Food Allowance/day (RM)</label>
            <input type="number" id="emp-food" placeholder="0 if none">
          </div>
          <div class="form-group">
            <label>Working Days/Month</label>
            <input type="number" id="emp-days" placeholder="26" value="26">
          </div>
          <div class="form-group">
            <label>Employment Type</label>
            <select id="emp-type">
              <option value="full">Full Time</option>
              <option value="part">Part Time</option>
            </select>
          </div>
          <div class="form-group">
            <label>IC Number</label>
            <input type="text" id="emp-ic" placeholder="e.g. 900101-14-1234">
          </div>
          <div class="form-group">
            <label>Start Date</label>
            <input type="date" id="emp-start">
          </div>
        </div>
        <div class="mt-16 flex flex-end">
          <button class="btn btn-blue" onclick="addEmployee()">Add Employee</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header green">Employee List</div>
      <div class="card-body">
        <div id="employee-list"></div>
      </div>
    </div>
  </div>

  <!-- ADVANCES -->
  <div id="tab-advances" class="tab-content">
    <div class="card">
      <div class="card-header orange">Record Salary Advance</div>
      <div class="card-body">
        <div class="form-grid">
          <div class="form-group">
            <label>Employee</label>
            <select id="adv-emp"></select>
          </div>
          <div class="form-group">
            <label>Amount (RM)</label>
            <input type="number" id="adv-amount" placeholder="e.g. 450">
          </div>
          <div class="form-group">
            <label>Date</label>
            <input type="date" id="adv-date">
          </div>
          <div class="form-group">
            <label>Month (deduct from)</label>
            <select id="adv-month">
              <option value="6">June 2026</option>
              <option value="7">July 2026</option>
              <option value="8">August 2026</option>
            </select>
          </div>
          <div class="form-group form-full">
            <label>Reason / Notes</label>
            <input type="text" id="adv-notes" placeholder="e.g. Weekly advance">
          </div>
        </div>
        <div class="mt-16 flex flex-end">
          <button class="btn btn-orange" style="background:var(--orange);color:white;" onclick="addAdvance()">Record Advance</button>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header black">Advance History</div>
      <div class="card-body">
        <div id="advance-list"></div>
      </div>
    </div>
  </div>

  <!-- DEDUCTIONS -->
  <div id="tab-deductions" class="tab-content">
    <div class="card">
      <div class="card-header red">Record Deduction</div>
      <div class="card-body">
        <div class="form-grid">
          <div class="form-group">
            <label>Employee</label>
            <select id="ded-emp"></select>
          </div>
          <div class="form-group">
            <label>Type</label>
            <select id="ded-type">
              <option value="late">Lateness</option>
              <option value="mistake">Work Mistake</option>
              <option value="absent">Absent Without Notice</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Amount (RM)</label>
            <input type="number" id="ded-amount" placeholder="e.g. 10">
          </div>
          <div class="form-group">
            <label>Date</label>
            <input type="date" id="ded-date">
          </div>
          <div class="form-group">
            <label>Month (deduct from)</label>
            <select id="ded-month">
              <option value="6">June 2026</option>
              <option value="7">July 2026</option>
              <option value="8">August 2026</option>
            </select>
          </div>
          <div class="form-group">
            <label>Notes</label>
            <input type="text" id="ded-notes" placeholder="e.g. Late 45 mins on 3 Jun">
          </div>
        </div>
        <div class="mt-16 flex flex-end">
          <button class="btn btn-red" onclick="addDeduction()">Record Deduction</button>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header black">Deduction History</div>
      <div class="card-body">
        <div id="deduction-list"></div>
      </div>
    </div>
  </div>

  <!-- PAYROLL -->
  <div id="tab-payroll" class="tab-content">
    <div class="card">
      <div class="card-header blue">
        Generate Payroll
      </div>
      <div class="card-body">
        <div class="form-grid">
          <div class="form-group">
            <label>Select Month</label>
            <select id="pay-month">
              <option value="6">June 2026</option>
              <option value="7">July 2026</option>
              <option value="8">August 2026</option>
            </select>
          </div>
          <div class="form-group">
            <label>Select Employee (or All)</label>
            <select id="pay-emp">
              <option value="all">All Employees</option>
            </select>
          </div>
        </div>
        <div class="mt-16 flex flex-end" style="gap:10px;">
          <button class="btn btn-blue" onclick="generatePayroll()">Generate Payroll</button>
          <button class="btn btn-yellow" onclick="printPayslips()">Print Payslips</button>
        </div>
      </div>
    </div>
    <div id="payroll-output"></div>
  </div>

</div>

<!-- MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-header" id="modal-header">Title</div>
    <div class="modal-body" id="modal-body"></div>
    <div class="modal-footer">
      <button class="btn btn-grey" onclick="closeModal()">Cancel</button>
      <button class="btn btn-red" id="modal-confirm">Confirm</button>
    </div>
  </div>
</div>

<script>
// ── DATA STORE ────────────────────────────────────────────────────────────────
let data = {
  employees: [],
  advances: [],
  deductions: []
};

// Load from localStorage
function loadData() {
  const saved = localStorage.getItem('gwira_payroll');
  if (saved) data = JSON.parse(saved);
  
  // Pre-load existing staff if empty
  if (data.employees.length === 0) {
    data.employees = [
      { id: 1, name: 'Kasturi', role: 'Cashier & Admin', salary: 1900, food: 0, days: 26, type: 'full', ic: '', start: '2026-06-01' },
      { id: 2, name: 'Loges', role: 'Driver & Delivery', salary: 2100, food: 10, days: 26, type: 'full', ic: '', start: '2026-06-01' },
      { id: 3, name: 'Sattar', role: 'Shop Keeper & Printing', salary: 2500, food: 10, days: 26, type: 'full', ic: '', start: '2026-06-01' },
      { id: 4, name: 'Sanjithra', role: 'Part-Time Admin', salary: 75, food: 0, days: 4, type: 'part', ic: '', start: '2026-06-01' },
    ];
    saveData();
  }
}

function saveData() {
  localStorage.setItem('gwira_payroll', JSON.stringify(data));
}

// ── EPF / SOCSO CALC ──────────────────────────────────────────────────────────
function calcEPF(salary) {
  if (salary <= 0) return { employee: 0, employer: 0 };
  // Standard EPF rates
  const employee = Math.round(salary * 0.11);
  const employer = Math.round(salary * 0.13);
  return { employee, employer };
}

function calcSOCSO(salary) {
  if (salary <= 0) return { employee: 0, employer: 0 };
  // SOCSO rate approx 0.5% employee, 1.75% employer (capped at RM4000)
  const base = Math.min(salary, 4000);
  const employee = Math.round(base * 0.005 * 100) / 100;
  const employer = Math.round(base * 0.0175 * 100) / 100;
  return { employee, employer };
}

function calcEIS(salary) {
  const base = Math.min(salary, 4000);
  const rate = 0.002;
  return { employee: Math.round(base * rate * 100) / 100, employer: Math.round(base * rate * 100) / 100 };
}

function getTotalSalary(emp) {
  return emp.salary + (emp.food * emp.days);
}

function getAdvancesForMonth(empId, month) {
  return data.advances.filter(a => a.empId === empId && a.month == month)
    .reduce((sum, a) => sum + a.amount, 0);
}

function getDeductionsForMonth(empId, month) {
  return data.deductions.filter(d => d.empId === empId && d.month == month)
    .reduce((sum, d) => sum + d.amount, 0);
}

function getMonthName(m) {
  const months = ['', 'January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'];
  return months[m];
}

// ── TAB SWITCHING ─────────────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  event.target.classList.add('active');
  renderAll();
}

// ── ADD EMPLOYEE ──────────────────────────────────────────────────────────────
function addEmployee() {
  const name = document.getElementById('emp-name').value.trim();
  const role = document.getElementById('emp-role').value.trim();
  const salary = parseFloat(document.getElementById('emp-salary').value) || 0;
  const food = parseFloat(document.getElementById('emp-food').value) || 0;
  const days = parseInt(document.getElementById('emp-days').value) || 26;
  const type = document.getElementById('emp-type').value;
  const ic = document.getElementById('emp-ic').value.trim();
  const start = document.getElementById('emp-start').value;

  if (!name || !salary) {
    alert('Please fill in at least the name and salary.');
    return;
  }

  const emp = {
    id: Date.now(),
    name, role, salary, food, days, type, ic, start, active: true
  };
  data.employees.push(emp);
  saveData();

  // Clear form
  ['emp-name','emp-role','emp-salary','emp-food','emp-ic','emp-start'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('emp-days').value = '26';

  renderAll();
  showAlert('Employee added successfully!', 'green');
}

// ── ADD ADVANCE ───────────────────────────────────────────────────────────────
function addAdvance() {
  const empId = parseInt(document.getElementById('adv-emp').value);
  const amount = parseFloat(document.getElementById('adv-amount').value) || 0;
